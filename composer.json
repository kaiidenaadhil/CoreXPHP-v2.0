{
    "name": "kaiidenaadhil/corexphp",
    "description": "CoreXPHP MVC Framework",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "phpmailer/phpmailer": "^6.9",
        "firebase/php-jwt": "^6.11"
    },
    "autoload": {
        "files": [
            "app/core/Function.php"
        ],
        "classmap": [
            "app/core/",
            "app/controllers/",
            "app/middlewares/",
            "app/models/",
            "app/services/"
        ]
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php -r \"file_exists('app/config/.env') || copy('app/config/local.env', 'app/config/.env');\""
        ]
    }
}
